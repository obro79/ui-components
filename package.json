{
  "name": "ui-made-easy",
  "private": true,
  "version": "0.3.0",
  "description": "Desktop-first UI ideation workbench with 24 authentic styles, live system controls, builder-essential components, comparison, and TypeScript export.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obro79/ui-made-easy.git"
  },
  "homepage": "https://github.com/obro79/ui-made-easy#readme",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "test": "npm run test:unit && npm run test:styles",
    "test:unit": "vitest run --exclude tests/export-project.test.ts",
    "test:styles": "node scripts/validate-style-catalog.mjs",
    "test:e2e": "playwright test tests/e2e --project=chromium",
    "test:visual": "playwright test tests/visual --project=chromium",
    "test:visual:update": "playwright test tests/visual --project=chromium --update-snapshots",
    "test:export": "vitest run tests/export-project.test.ts",
    "capture:readme": "node scripts/capture-readme.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tanstack/react-table": "^8.21.3",
    "@vitejs/plugin-react": "latest",
    "cmdk": "^1.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "latest",
    "react": "latest",
    "react-day-picker": "^10.0.1",
    "react-dom": "latest",
    "sonner": "^2.0.7",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.3",
    "vitest": "^4.1.10"
  }
}
